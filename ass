                                            <input type="text" name="locaisEmbarque" value={formData.locaisEmbarque} onChange={handleInputChange} className="w-full px-4 py-2.5 border border-slate-300 rounded-lg outline-none bg-slate-50" placeholder="Liste os pontos de encontro" required />
